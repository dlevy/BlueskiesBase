{
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "api/[...path].js": {
      "includeFiles": "server/**"
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/sitemap.xml", "dest": "/api/[...path].js" },
    { "src": "/api/(.*)", "dest": "/api/[...path].js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
