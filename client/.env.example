# Frontend Environment Variables
# Copy this file to .env and fill in your actual values

# Supabase Configuration (public keys only — anon key is safe to expose)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# API base URL
# Leave blank (or omit) for production — API routes are served from the same Vercel domain
# For local dev with 'vercel dev': leave blank (same port)
# For local dev with 'vite dev' only: vite.config.js proxies /api to localhost:3000 automatically
# VITE_API_BASE_URL=

# Get these from: Supabase Dashboard → Project Settings → API
# Use the ANON/PUBLIC key (not the service role key) for frontend
